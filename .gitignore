# macOS / Linux local noise
.DS_Store
*.swp
*.swo
*~

# Terraform generated files (never commit)
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
*.env

# Keep dependency lock file committed for reproducibility
!**/.terraform.lock.hcl
